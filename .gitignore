# Snakemake execution state
.snakemake/
logs/
results/

# Generated workflow data
data/curated/
data/sequence/
data/sequences/
data/processed/
data/structures/
data/external/

# User-supplied raw inputs
data/raw/*
!data/raw/.gitkeep

# Reference structures supplied by the user
data/reference_structures/GH10/*
data/reference_structures/GH11/*
!data/reference_structures/GH10/.gitkeep
!data/reference_structures/GH11/.gitkeep

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Conda and virtual environments
.conda/
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Editors and operating systems
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak

# Credentials
.env
*.key
*.pem

